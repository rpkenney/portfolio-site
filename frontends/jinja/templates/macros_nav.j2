{# Global nav — hrefs from nav_for (Python); labels from discovered routes. #}

{% macro site_nav(nav) -%}
<nav class="site-nav" aria-label="Site" data-site-nav>
  <button
    type="button"
    class="site-nav-toggle"
    aria-controls="site-nav-list"
    aria-expanded="false"
    data-site-nav-toggle
  >
    Menu
  </button>
  <ul class="site-nav-list" id="site-nav-list">
    {% for item in nav.links %}
    <li>
      <a
        href="{{ item.href }}"
        class="site-nav-link{% if nav.current_page == item.nav_key or nav.current_page in item.current_aliases %} site-nav-link--current{% endif %}"
        {% if nav.current_page == item.nav_key %}aria-current="page"{% endif %}
      >{{ item.label }}</a>
    </li>
    {% endfor %}
  </ul>
</nav>
{%- endmacro %}
