{# §4 Global nav — hrefs are computed in Python for root vs nested pages. #}

{% macro site_nav(nav) -%}
<nav class="site-nav" aria-label="Site" data-site-nav>
  <button
    type="button"
    class="site-nav-toggle"
    aria-controls="site-nav-list"
    aria-expanded="false"
    data-site-nav-toggle
  >
    Menu
  </button>
  <ul class="site-nav-list" id="site-nav-list">
    <li>
      <a
        href="{{ nav.home_href }}"
        class="site-nav-link{% if nav.current_page == 'home' %} site-nav-link--current{% endif %}"
        {% if nav.current_page == 'home' %}aria-current="page"{% endif %}
      >Résumé</a>
    </li>
    <li>
      <a
        href="{{ nav.portfolio_href }}"
        class="site-nav-link{% if nav.current_page == 'portfolio' %} site-nav-link--current{% endif %}"
        {% if nav.current_page == 'portfolio' %}aria-current="page"{% endif %}
      >Portfolio</a>
    </li>
    <li>
      <a
        href="{{ nav.writings_href }}"
        class="site-nav-link{% if nav.current_page == 'writings' or nav.current_page == 'writing_post' %} site-nav-link--current{% endif %}"
        {% if nav.current_page == 'writings' %}aria-current="page"{% endif %}
      >Writings</a>
    </li>
  </ul>
</nav>
{%- endmacro %}
